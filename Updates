    successMsg.style.fontSize = '0.85rem';
    successMsg.style.marginTop = '0.5rem';
    msgDiv.parentNode.insertBefore(successMsg, msgDiv.nextSibling);
    setTimeout(() => successMsg.remove(), 3000);
}

