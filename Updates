// LOCAL STORAGE FUNCTIONS - Add to existing script

// Load propagation data from localStorage on page load
function loadPropagationData() {
    const savedData = localStorage.getItem('propagationRecords');
    if (savedData) {
        const tbody = document.getElementById('propagationTableBody');
        tbody.innerHTML = savedData;
        // Re-attach delete handlers to new rows
        document.querySelectorAll('#propagationTableBody .btn-outline').forEach(btn => {
            btn.onclick = function() { deleteRow(this); savePropagationData(); };
        });
    }
}

// Save propagation data to localStorage
function savePropagationData() {
    const tbody = document.getElementById('propagationTableBody');
    localStorage.setItem('propagationRecords', tbody.innerHTML);
}

// Load environmental data from localStorage on page load
function loadEnvData() {
    const savedData = localStorage.getItem('envRecords');
    if (savedData) {
        const tbody = document.getElementById('envTableBody');
