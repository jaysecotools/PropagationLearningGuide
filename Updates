function applyPropFilters() {
    const searchTerm = document.getElementById('propSearchInput')?.value.toLowerCase() || '';
    const methodFilter = document.getElementById('propMethodFilter')?.value || '';
    const rows = document.querySelectorAll('#propagationTableBody tr');
    let visibleCount = 0;
    
    rows.forEach(row => {
        const species = row.cells[1]?.innerText.toLowerCase() || '';
        const source = row.cells[3]?.innerText.toLowerCase() || '';
        const notes = row.cells[7]?.innerText.toLowerCase() || '';
        const method = row.cells[2]?.innerText.toLowerCase() || '';
        
        const matchesSearch = searchTerm === '' || species.includes(searchTerm) || source.includes(searchTerm) || notes.includes(searchTerm);
        const matchesMethod = methodFilter === '' || method === methodFilter.toLowerCase();
        
        if (matchesSearch && matchesMethod) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });
    
    const countSpan = document.getElementById('propRecordCount');
    if (countSpan) countSpan.innerHTML = `<i class="fas fa-list"></i> ${visibleCount} record${visibleCount !== 1 ? 's' : ''} shown`;
}

