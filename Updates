function resetQuizzesExpanded() {
    // Reset all radio button selections
    document.querySelectorAll('.quiz-question input[type="radio"]').forEach(input => {
        input.checked = false;
    });
    
    // Find and clear all feedback elements
    // This targets any element with class 'quiz-feedback' that appears after each question
    const allFeedbackDivs = document.querySelectorAll('.quiz-feedback');
    allFeedbackDivs.forEach(fb => {
        // Clear the HTML content
        fb.innerHTML = '';
        // Hide the feedback div
        fb.style.display = 'none';
        // Remove any styling classes that might have been added
        fb.classList.remove('feedback-correct', 'feedback-incorrect');
    });
    
    // Clear the overall score display
    const scoreDiv = document.getElementById('quizScore');
    if (scoreDiv) {
        scoreDiv.innerHTML = '';
    }
}
