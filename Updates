2. Add these JavaScript functions to your existing script (before the DOMContentLoaded event listener):

```javascript
// ============ EXPAND/COLLAPSE ALL SPECIES CARDS ============

function expandAllSpeciesCards() {
    const allCards = document.querySelectorAll('.species-card');
    allCards.forEach(card => {
        card.classList.add('open');
    });
}

function collapseAllSpeciesCards() {
    const allCards = document.querySelectorAll('.species-card');
    allCards.forEach(card => {
        card.classList.remove('open');
    });
}
```

3. Update your renderSpecies function to ensure that when you search/filter, the expand/collapse state is preserved or reset appropriately. Replace your existing renderSpecies function with this improved version:

```javascript
function renderSpecies() {
    const grid = document.getElementById('speciesGrid');
    if(!grid) return;
    const search = document.getElementById('speciesSearch')?.value.toLowerCase() || '';
    const filtered = speciesDB.filter(s => s.name.toLowerCase().includes(search) || s.family.toLowerCase().includes(search) || s.method.toLowerCase().includes(search));
    
    // Store which cards were open before re-render (by species name)
    const openSpecies = new Set();
    document.querySelectorAll('.species-card.open').forEach(card => {
        const titleElem = card.querySelector('.species-title strong');
        if (titleElem) {
            openSpecies.add(titleElem.innerText);
        }
    });
    
    grid.innerHTML = filtered.map((s, i) => `
    <div class="species-card ${openSpecies.has(s.name) ? 'open' : ''}" onclick="toggleSpeciesCard(this)">
        <div class="species-title">
            <i class="fas fa-leaf"></i> <strong>${s.name}</strong>
        </div>
        <div class="species-details">
            <span style="font-size:0.85rem;">
                Family: ${s.family}<br>
                Method: ${s.method}<br>
                Treatment: ${s.treatment}<br>
                Conservation: ${s.conservation}
            </span>
        </div>
    </div>
`).join('');
}

function toggleSpeciesCard(card) {
    // If we're clicking a card while holding Ctrl/Cmd, we can toggle individually without affecting others
    // But standard behavior: just toggle this one
    card.classList.toggle('open');
}
```

