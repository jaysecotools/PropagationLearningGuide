}

// ============ JSON BACKUP/RESTORE FUNCTIONS ============

function exportToJSON() {
    const propData = localStorage.getItem('propagationRecords');
    const envData = localStorage.getItem('envRecords');
    
    // Create a clean backup object with the raw HTML strings
    const backupData = {
        version: '1.0',
        exportedAt: new Date().toISOString(),
        propagationRecords: propData || '',
        environmentalRecords: envData || ''
    };
    
    const jsonStr = JSON.stringify(backupData, null, 2);
    const blob = new Blob([jsonStr], {type: 'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `propagation_backup_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
    
    alert('✅ Backup exported successfully!');
}

function importFromJSON(fileInput) {
    const file = fileInput.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const backupData = JSON.parse(e.target.result);
            
            // Validate the backup structure
            if (backupData.version && backupData.propagationRecords !== undefined) {
                if (backupData.propagationRecords) {
                    localStorage.setItem('propagationRecords', backupData.propagationRecords);
                }
                if (backupData.environmentalRecords !== undefined) {
                    localStorage.setItem('envRecords', backupData.environmentalRecords || '');
                }
                
                // Reload the data from localStorage
                loadPropagationData();
                loadEnvData();
                
                alert('✅ Restore successful! Your records have been restored.');
            } else {
                throw new Error('Invalid backup file format');
            }
        } catch (err) {
            console.error('Restore error:', err);
            alert('❌ Error: Invalid backup file. Please select a valid JSON backup from this application.');
        }
    };
    reader.onerror = function() {
        alert('❌ Error reading file.');
    };
    reader.readAsText(file);
    fileInput.value = ''; // Reset file input
}

// ============ STORAGE INFO & CLEAR FUNCTIONS ============

function showStorageInfo() {
    let propSize = localStorage.getItem('propagationRecords')?.length || 0;
    let envSize = localStorage.getItem('envRecords')?.length || 0;
    let totalSize = (propSize + envSize) / 1024;
    let recordCount = document.querySelectorAll('#propagationTableBody tr').length;
    let envCount = document.querySelectorAll('#envTableBody tr').length;
    alert(`📊 Local Storage Summary:\n\nPropagation Records: ${recordCount} records (${propSize} characters)\nEnvironmental Records: ${envCount} records (${envSize} characters)\nTotal storage: ~${totalSize.toFixed(1)} KB\n\nLocalStorage limit is 5-10 MB per domain.`);
}

function clearAllStorage() {
    if (confirm('⚠️ WARNING: This will permanently delete ALL your saved propagation and environmental records. This cannot be undone. Are you sure?')) {
        localStorage.removeItem('propagationRecords');
        localStorage.removeItem('envRecords');
        loadPropagationData();
        loadEnvData();
        alert('All records have been cleared and reset to defaults.');
    }
}

// ============ EXPORT CSV ============

function exportData() {
    let csv = "Propagation Records\nDate,Species,Method,Source,Units,Media,Rooting %,Notes\n";
    document.querySelectorAll('#propagationTableBody tr').forEach(row => {
        if (row.style.display !== 'none') {
            const cells = row.querySelectorAll('td');
            if (cells.length) {
                const speciesText = cells[1]?.innerText.replace(/<[^>]*>/g, '').trim() || '';
                csv += `"${cells[0]?.innerText}","${speciesText}","${cells[2]?.innerText}","${cells[3]?.innerText}","${cells[4]?.innerText}","${cells[5]?.innerText}","${cells[6]?.innerText}","${cells[7]?.innerText}"\n`;
            }
        }
    });
    csv += "\nEnvironmental Logs\nDate,Time,Air Temp,Media Temp,RH%,Mist sec/hr,Light lux,Pests,Action\n";
    document.querySelectorAll('#envTableBody tr').forEach(row => {
        if (row.style.display !== 'none') {
            const cells = row.querySelectorAll('td');
            if (cells.length) {
                csv += `"${cells[0]?.innerText}","${cells[1]?.innerText}","${cells[2]?.innerText}","${cells[3]?.innerText}","${cells[4]?.innerText}","${cells[5]?.innerText}","${cells[6]?.innerText}","${cells[7]?.innerText}","${cells[8]?.innerText}"\n`;
            }
        }
    });
    const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `propagation_records_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
    URL.revokeObjectURL(a.href);
}

// ============ DOMContentLoaded ============

document.addEventListener('DOMContentLoaded', () => {
    renderSpecies();
    if(document.getElementById('speciesSearch')) document.getElementById('speciesSearch').addEventListener('input', renderSpecies);
    
    // Load saved data from localStorage
    loadPropagationData();
    loadEnvData();
    
    // Attach search/filter event listeners
    const propSearch = document.getElementById('propSearchInput');
    const propFilter = document.getElementById('propMethodFilter');
    const envSearch = document.getElementById('envSearchInput');
    
    if (propSearch) propSearch.addEventListener('input', applyPropFilters);
    if (propFilter) propFilter.addEventListener('change', applyPropFilters);
    if (envSearch) envSearch.addEventListener('input', applyEnvFilters);
});
