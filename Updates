// Show storage usage info (optional utility)
function showStorageInfo() {
    let propSize = localStorage.getItem('propagationRecords')?.length || 0;
    let envSize = localStorage.getItem('envRecords')?.length || 0;
    let totalSize = (propSize + envSize) / 1024;
    alert(`📊 Local Storage Usage:\nPropagation Records: ${propSize} characters\nEnvironmental Records: ${envSize} characters\nTotal: ~${totalSize.toFixed(1)} KB\n\nLocalStorage limit is typically 5-10 MB per domain.`);
}

// MODIFIED addPropagationRow function with save
function addPropagationRow() {
    const tbody = document.getElementById('propagationTableBody');
    const date = document.getElementById('newDate').value || new Date().toISOString().slice(0,10);
    const species = document.getElementById('newSpecies').value || 'Unknown';
    const method = document.getElementById('newMethod').value;
    const source = document.getElementById('newSource').value || '-';
    const units = document.getElementById('newUnits').value || '0';
    const media = document.getElementById('newMedia').value || '-';
    const rooting = document.getElementById('newRooting').value || '-';
    const notes = document.getElementById('newNotes').value || '-';
    const row = `<tr><td>${date}</td><td><em>${species}</em></td><td>${method}</td><td>${source}</td><td>${units}</td><td>${media}</td><td>${rooting}%</td><td>${notes}</td><td><button class="btn btn-outline" style="padding:2px 8px;" onclick="deleteRow(this)"><i class="fas fa-trash"></i></button></td></tr>`;
    tbody.insertAdjacentHTML('beforeend', row);
    savePropagationData();
    // Clear inputs
    document.getElementById('newSpecies').value = '';
    document.getElementById('newSource').value = '';
    document.getElementById('newUnits').value = '';
    document.getElementById('newMedia').value = '';
