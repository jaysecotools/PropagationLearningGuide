<!-- TAB 8: RECORDS & LOGS - Enhanced with localStorage, validation, search/filter -->
<div id="tab8" class="tab-content">
    <h2><i class="fas fa-table"></i> Propagation Records & Environmental Logs</h2>
    
    <!-- Data Management Toolbar -->
    <div style="background: var(--bg-light); border-radius: 1rem; padding: 1rem; margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; justify-content: space-between;">
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
            <button class="btn btn-primary" onclick="exportToJSON()"><i class="fas fa-file-export"></i> Backup (JSON)</button>
            <button class="btn btn-outline" onclick="document.getElementById('importFile').click()"><i class="fas fa-file-import"></i> Restore (JSON)</button>
            <input type="file" id="importFile" accept=".json" style="display: none;" onchange="importFromJSON(this)">
            <button class="btn btn-outline" onclick="showStorageInfo()"><i class="fas fa-database"></i> Storage Info</button>
            <button class="btn btn-danger" onclick="clearAllStorage()"><i class="fas fa-trash-alt"></i> Clear All Records</button>
        </div>
        <div style="font-size: 0.85rem; color: var(--text-light);">
            <i class="fas fa-save"></i> Auto-saved to browser • Data persists after refresh
        </div>
    </div>

    <div class="card">
        <h3>📊 Propagation Record Sheet</h3>
        <p>Track your propagation batches. All data auto-saves to your browser.</p>
        
        <!-- Search/Filter Bar -->
        <div style="background: var(--primary-soft); border-radius: 1rem; padding: 0.8rem; margin: 1rem 0; display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center;">
            <i class="fas fa-search" style="color: var(--primary);"></i>
            <input type="text" id="propSearchInput" placeholder="Search species, source, or notes..." style="flex: 2; padding: 8px; border: 1px solid var(--border); border-radius: 8px; min-width: 180px;">
            <select id="propMethodFilter" style="padding: 8px; border: 1px solid var(--border); border-radius: 8px;">
                <option value="">All Methods</option>
                <option>Seed</option>
                <option>Cutting</option>
                <option>Division</option>
                <option>Grafting</option>
                <option>Layering</option>
            </select>
            <button class="btn btn-outline" onclick="clearPropFilters()" style="padding: 6px 12px;"><i class="fas fa-times"></i> Clear Filters</button>
            <span id="propRecordCount" style="margin-left: auto; font-size: 0.85rem;"><i class="fas fa-list"></i> 0 records</span>
        </div>
        
        <div class="data-table-container">
            <table id="propagationTable" style="min-width: 900px;">
                <thead>
                    <tr><th>Date</th><th>Species</th><th>Method</th><th>Source Location</th><th># Units</th><th>Media</th><th>Rooting %</th><th>Notes</th><th>Actions</th></tr>
                </thead>
                <tbody id="propagationTableBody"></tbody>
            </table>
        </div>
        
        <div class="data-table-controls">
            <input type="date" id="newDate" placeholder="Date">
            <input type="text" id="newSpecies" placeholder="Species*" style="flex:2;" required>
            <select id="newMethod"><option>Seed</option><option>Cutting</option><option>Division</option><option>Grafting</option><option>Layering</option></select>
            <input type="text" id="newSource" placeholder="Source Location">
            <input type="number" id="newUnits" placeholder="# Units" style="width:80px;" min="0">
            <input type="text" id="newMedia" placeholder="Media">
            <input type="text" id="newRooting" placeholder="Rooting %" style="width:70px;">
            <input type="text" id="newNotes" placeholder="Notes" style="flex:2;">
            <button class="btn" onclick="addPropagationRowWithValidation()"><i class="fas fa-plus"></i> Add Row</button>
        </div>
        <div id="propValidationMsg" style="color: #b34343; font-size: 0.85rem; margin-top: 0.5rem;"></div>
    </div>

    <div class="card">
        <h3>🌡️ Environmental Monitoring Log</h3>
        <p>Record daily environmental conditions in the propagation facility.</p>
        
        <!-- Search/Filter Bar for Environmental Log -->
        <div style="background: var(--primary-soft); border-radius: 1rem; padding: 0.8rem; margin: 1rem 0; display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center;">
            <i class="fas fa-search" style="color: var(--primary);"></i>
            <input type="text" id="envSearchInput" placeholder="Search by date, pests, or actions..." style="flex: 2; padding: 8px; border: 1px solid var(--border); border-radius: 8px; min-width: 180px;">
            <button class="btn btn-outline" onclick="clearEnvFilters()" style="padding: 6px 12px;"><i class="fas fa-times"></i> Clear Filters</button>
            <span id="envRecordCount" style="margin-left: auto; font-size: 0.85rem;"><i class="fas fa-list"></i> 0 records</span>
        </div>
        
        <div class="data-table-container">
            <table id="envTable" style="min-width: 1000px;">
                <thead><tr><th>Date</th><th>Time</th><th>Air Temp °C</th><th>Media Temp °C</th><th>RH%</th><th>Mist (sec/hr)</th><th>Light (lux)</th><th>Pests Observed</th><th>Action Taken</th><th>Actions</th></tr></thead>
                <tbody id="envTableBody"></tbody>
            </table>
        </div>
        
        <div class="data-table-controls">
            <input type="date" id="envDate"><input type="time" id="envTime"><input type="number" id="envAirTemp" placeholder="Air Temp" step="0.1"><input type="number" id="envMediaTemp" placeholder="Media Temp" step="0.1"><input type="number" id="envRH" placeholder="RH%" min="0" max="100"><input type="number" id="envMist" placeholder="Mist sec/hr" min="0"><input type="number" id="envLight" placeholder="Light lux" min="0"><input type="text" id="envPests" placeholder="Pests"><input type="text" id="envAction" placeholder="Action"><button class="btn" onclick="addEnvRowWithValidation()"><i class="fas fa-plus"></i> Add Row</button>
        </div>
        <div id="envValidationMsg" style="color: #b34343; font-size: 0.85rem; margin-top: 0.5rem;"></div>
    </div>
    
    <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
        <button class="btn" onclick="exportData()"><i class="fas fa-download"></i> Export as CSV</button>
        <button class="btn btn-outline" onclick="window.print()"><i class="fas fa-print"></i> Print This Page</button>
    </div>
</div>
