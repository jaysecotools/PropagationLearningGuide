// ============ VALIDATION FUNCTIONS ============

function escapeHtml(str) {
    if (!str) return str;
    return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

function addPropagationRowWithValidation() {
    const species = document.getElementById('newSpecies').value.trim();
    const date = document.getElementById('newDate').value;
    const units = document.getElementById('newUnits').value;
    const msgDiv = document.getElementById('propValidationMsg');
    
    if (!species) {
        msgDiv.innerHTML = '❌ Species name is required.';
        document.getElementById('newSpecies').focus();
        return;
    }
    if (species.length < 2) {
        msgDiv.innerHTML = '❌ Species name must be at least 2 characters.';
        return;
    }
    if (!date) {
        msgDiv.innerHTML = '❌ Please select a date.';
        return;
    }
    if (units && (isNaN(units) || units < 0)) {
        msgDiv.innerHTML = '❌ Units must be a positive number.';
        return;
    }
    
    msgDiv.innerHTML = '';
    
    const tbody = document.getElementById('propagationTableBody');
    const method = document.getElementById('newMethod').value;
    const source = document.getElementById('newSource').value || '-';
    const media = document.getElementById('newMedia').value || '-';
    const rooting = document.getElementById('newRooting').value || '-';
    const notes = document.getElementById('newNotes').value || '-';
    
    const row = `<tr><td>${date}</td><td><em>${escapeHtml(species)}</em></td><td>${escapeHtml(method)}</td><td>${escapeHtml(source)}</td><td>${units || '0'}</td><td>${escapeHtml(media)}</td><td>${rooting}%</td><td>${escapeHtml(notes)}</td><td><button class="btn btn-outline" style="padding:2px 8px;" onclick="deleteRow(this)"><i class="fas fa-trash"></i></button></td></tr>`;
    tbody.insertAdjacentHTML('beforeend', row);
    savePropagationData();
    attachDeleteHandlers();
    
    document.getElementById('newSpecies').value = '';
    document.getElementById('newSource').value = '';
    document.getElementById('newUnits').value = '';
    document.getElementById('newMedia').value = '';
    document.getElementById('newRooting').value = '';
    document.getElementById('newNotes').value = '';
    document.getElementById('newDate').value = '';
    
    const successMsg = document.createElement('div');
    successMsg.innerHTML = '✅ Record added successfully!';
    successMsg.style.color = '#2c7840';
    successMsg.style.fontSize = '0.85rem';
    successMsg.style.marginTop = '0.5rem';
    msgDiv.parentNode.insertBefore(successMsg, msgDiv.nextSibling);
    setTimeout(() => successMsg.remove(), 3000);
}

