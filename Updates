function renderSpecies() {
    const grid = document.getElementById('speciesGrid');
    if(!grid) return;
    const search = document.getElementById('speciesSearch')?.value.toLowerCase() || '';
    const filtered = speciesDB.filter(s => s.name.toLowerCase().includes(search) || s.family.toLowerCase().includes(search) || s.method.toLowerCase().includes(search));
    grid.innerHTML = filtered.map(s => `<div class="species-card"><i class="fas fa-leaf"></i> <strong>${s.name}</strong><br><span style="font-size:0.85rem;">Family: ${s.family}<br>Method: ${s.method}<br>Treatment: ${s.treatment}<br>Conservation: ${s.conservation}</span></div>`).join('');
}

function switchTab(event, tabId) {
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
    event.currentTarget.classList.add('active');
    window.scrollTo(0,0);
}

function checkQuizzesExpanded() {
    let score = 0, total = 10;
    for(let i = 1; i <= total; i++) {
        const radioGroup = document.querySelectorAll(`input[name="quiz${i}"]`);
        if(!radioGroup.length) continue;
        const selected = Array.from(radioGroup).find(r => r.checked);
        const questionDiv = radioGroup[0]?.closest('.quiz-question');
        if(!questionDiv) continue;
        const fbDiv = questionDiv.querySelector('.quiz-feedback');
        if(!fbDiv) continue;
        const correct = questionDiv.dataset.correct;
        if(selected && selected.value === correct) {
            fbDiv.innerHTML = '✓ Correct!';
            fbDiv.className = 'feedback-correct';
            score++;
        } else if(selected) {
            fbDiv.innerHTML = '✗ Incorrect. Review the material.';
            fbDiv.className = 'feedback-incorrect';
        } else {
            fbDiv.innerHTML = '⚠ Please select an answer.';
            fbDiv.className = 'feedback-incorrect';
        }
        fbDiv.style.display = 'block';
    }
    document.getElementById('quizScore').innerHTML = `<strong>Score: ${score}/${total}</strong> ${score===total ? 'Excellent! You are well prepared.' : 'Review and try again. Aim for 80%+.'}`;
}

function resetQuizzesExpanded() {
    document.querySelectorAll('.quiz-question input').forEach(i => i.checked=false);
    document.querySelectorAll('.quiz-feedback').forEach(f => { f.style.display='none'; f.innerHTML=''; });
    document.getElementById('quizScore').innerHTML = '';
}

function selectScenario(event, num, choice) {
    const opts = document.querySelectorAll(`#scen${num}opts .scenario-option`);
    opts.forEach(o => o.classList.remove('selected'));
    event.currentTarget.classList.add('selected');
    const msgs = {
        1: { B: "✅ Correct: young, vigorous, pest-free parent plants produce healthier cuttings with better rooting success and disease resistance." },
        2: { B: "✅ Correct: remove affected material, improve airflow, reduce mist, apply fungicide - prevents spread and addresses the underlying cause (excess humidity)." },
        3: { B: "✅ Correct: Acacia requires hot water scarification to break physical dormancy. Re-treat remaining seed and re-sow." },
        4: { B: "✅ Correct: Phytophthora hygiene is critical. Boot wash, tool sterilisation, avoid collecting from symptomatic plants, and quarantine new material." }
    };
    const msg = msgs[num]?.[choice] || "Review the scenario and try again.";
    const fb = document.getElementById(`scen${num}fb`);
    fb.innerHTML = `<strong>Feedback:</strong> ${msg}`;
    fb.style.display = 'block';
}

function resetScenario(num) {
    document.getElementById(`scen${num}fb`).style.display = 'none';
    document.querySelectorAll(`#scen${num}opts .scenario-option`).forEach(o => o.classList.remove('selected'));
}

