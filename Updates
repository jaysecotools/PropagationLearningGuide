// ============ SEARCH & FILTER FUNCTIONS ============

function applyPropFilters() {
    const searchTerm = document.getElementById('propSearchInput')?.value.toLowerCase() || '';
    const methodFilter = document.getElementById('propMethodFilter')?.value || '';
    const rows = document.querySelectorAll('#propagationTableBody tr');
    let visibleCount = 0;
    
    rows.forEach(row => {
        const species = row.cells[1]?.innerText.toLowerCase() || '';
        const source = row.cells[3]?.innerText.toLowerCase() || '';
        const notes = row.cells[7]?.innerText.toLowerCase() || '';
        const method = row.cells[2]?.innerText.toLowerCase() || '';
        
        const matchesSearch = searchTerm === '' || species.includes(searchTerm) || source.includes(searchTerm) || notes.includes(searchTerm);
        const matchesMethod = methodFilter === '' || method === methodFilter.toLowerCase();
        
        if (matchesSearch && matchesMethod) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });
    
    const countSpan = document.getElementById('propRecordCount');
    if (countSpan) countSpan.innerHTML = `<i class="fas fa-list"></i> ${visibleCount} record${visibleCount !== 1 ? 's' : ''} shown`;
}

function applyEnvFilters() {
    const searchTerm = document.getElementById('envSearchInput')?.value.toLowerCase() || '';
    const rows = document.querySelectorAll('#envTableBody tr');
    let visibleCount = 0;
    
    rows.forEach(row => {
        const date = row.cells[0]?.innerText.toLowerCase() || '';
        const pests = row.cells[7]?.innerText.toLowerCase() || '';
        const action = row.cells[8]?.innerText.toLowerCase() || '';
        
        const matchesSearch = searchTerm === '' || date.includes(searchTerm) || pests.includes(searchTerm) || action.includes(searchTerm);
        
        if (matchesSearch) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });
    
    const countSpan = document.getElementById('envRecordCount');
    if (countSpan) countSpan.innerHTML = `<i class="fas fa-list"></i> ${visibleCount} record${visibleCount !== 1 ? 's' : ''} shown`;
}

function clearPropFilters() {
    const searchInput = document.getElementById('propSearchInput');
    const methodFilter = document.getElementById('propMethodFilter');
    if (searchInput) searchInput.value = '';
    if (methodFilter) methodFilter.value = '';
    applyPropFilters();
}

function clearEnvFilters() {
    const searchInput = document.getElementById('envSearchInput');
    if (searchInput) searchInput.value = '';
    applyEnvFilters();
}

function updatePropRecordCount() {
    const count = document.querySelectorAll('#propagationTableBody tr').length;
    const countSpan = document.getElementById('propRecordCount');
    if (countSpan) countSpan.innerHTML = `<i class="fas fa-list"></i> ${count} total record${count !== 1 ? 's' : ''}`;
}

function updateEnvRecordCount() {
    const count = document.querySelectorAll('#envTableBody tr').length;
    const countSpan = document.getElementById('envRecordCount');
    if (countSpan) countSpan.innerHTML = `<i class="fas fa-list"></i> ${count} total record${count !== 1 ? 's' : ''}`;
}

